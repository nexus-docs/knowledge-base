# ──────────────────────────────────────────────
# Nexus Docs — Environment Configuration
# Copy to .env and fill in your values
# ──────────────────────────────────────────────

# Database
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus
POSTGRES_DB=nexus
DATABASE_URL=postgresql://nexus:nexus@db:5432/nexus

# Redis (BullMQ queue backend)
REDIS_URL=redis://redis:6379

# Meilisearch
MEILISEARCH_URL=http://search:7700
MEILISEARCH_KEY=change-this-in-production
MEILI_ENV=development

# Auth
AUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Content (local dev override)
CONTENT_DIR=

# GitLab OAuth (create app at GitLab → Admin → Applications)
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=

# GitLab (content repo + issue/branch creation)
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_CONTENT_PROJECT_ID=
GITLAB_CONTENT_BRANCH=main

# Magento (license verification + user sync)
MAGENTO_API_URL=
MAGENTO_API_TOKEN=

# AI (Claude API for doc review + chat)
CLAUDE_API_KEY=

# Email (Resend — or use SMTP_* for fallback)
RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
EMAIL_FROM=portal@qoliber.com

# GitHub (PR hooks for AI repo scan — Phase 2)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Invitations (API key for Magento integration)
INVITATION_API_KEY=generate-with-openssl-rand-base64-32

# Webhooks
WEBHOOK_SECRET=generate-with-openssl-rand-base64-32

# Site
NEXT_PUBLIC_SITE_URL=https://docs.qoliber.com
NEXT_PUBLIC_SITE_NAME=qoliber Docs

# SEO
GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_GTM_ID=
